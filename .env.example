# ============================================================
# OutfAI — environment variable template
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# ------------------------------------------------------------
# Database
# Docker Compose (dev): host port 5433 → container port 5432.
# Supabase local stack: use 127.0.0.1:54322 instead.
# ------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/outfai

# ------------------------------------------------------------
# Supabase (hosted project — leave blank for local Postgres only)
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ------------------------------------------------------------
# Auth (BetterAuth)
# Generate a secret with: openssl rand -base64 32
# ------------------------------------------------------------
BETTER_AUTH_SECRET=change-me-to-a-random-32-char-string
BETTER_AUTH_URL=http://localhost:3000

# ------------------------------------------------------------
# Google Cloud Vision (garment image recognition / auto-fill attributes)
# Set this in .env.local only, e.g.:
#   GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\your-vision-key.json
# ------------------------------------------------------------
GOOGLE_APPLICATION_CREDENTIALS=

# ------------------------------------------------------------
# Weather API
# Open-Meteo is free and requires no key.
# Uncomment if you switch to OpenWeatherMap.
# ------------------------------------------------------------
# OPENWEATHERMAP_API_KEY=

# ------------------------------------------------------------
# Postgres overrides (used by docker-compose.prod.yml)
# ------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=outfai
